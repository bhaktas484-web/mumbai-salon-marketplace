{
  "name": "@salon/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Glamr Mumbai — Backend API (Node.js + Express + MongoDB)",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:seed": "tsx src/utils/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.6",
    "redis": "^4.7.0",
    "slugify": "^1.6.6",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
